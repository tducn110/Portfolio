/* Page entrance handled by GSAP hero flow motion */

/* Responsive type scale */
@media (min-width: 620px) {
  .hero-title {
    font-size: 56px;
  }
}

@media (min-width: 920px) {
  .hero-title {
    font-size: 72px;
  }
}

@media (min-width: 1120px) {
  .hero-title {
    font-size: var(--text-display);
  }
}

@media (max-width: 980px) {
  .announcement-bar {
    grid-template-columns: 1fr auto;
  }

  .announcement-bar p {
    text-align: left;
  }

  .announcement-bar button:not(.announcement-close) {
    display: none;
  }

  .nav-shell {
    grid-template-columns: 1fr auto;
  }

  .nav-links,
  .nav-actions {
    display: none;
  }

  .mobile-toggle {
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  .mobile-menu {
    display: grid;
    gap: 2px;
    padding: 12px 24px 20px;
    border-bottom: 1px solid var(--color-ink-black);
    background: var(--color-parchment-cream);
  }

  .mobile-menu button,
  .mobile-menu a {
    padding: 12px 0;
    color: var(--color-ink-black);
    text-align: left;
    font-size: 14px;
  }

  .data-flow {
    grid-template-columns: 1fr;
    min-height: auto;
  }

  .flow-lines {
    display: none;
  }

  .flow-column,
  .flow-column:first-of-type,
  .flow-column:last-of-type {
    align-items: center;
  }

  .flow-column {
    flex-flow: row wrap;
    justify-content: center;
  }

  .processor {
    min-height: 280px;
  }

  .hero-facts {
    grid-template-columns: repeat(2, 1fr);
  }

  .hero-facts div:nth-child(2) {
    border-right: 0;
  }

  .hero-facts div:nth-child(-n + 2) {
    border-bottom: 1px solid rgba(0, 0, 0, 0.24);
  }

  .origin-grid,
  .project-card,
  .process-panel,
  .service-detail-grid,
  .service-card,
  .contact-grid {
    grid-template-columns: 1fr;
  }

  .origin-grid .feature-card,
  .origin-grid .feature-card:first-child,
  .origin-grid .feature-card:nth-child(2),
  .origin-grid .feature-card:nth-child(3) {
    grid-column: span 1;
  }

  .project-card {
    gap: 18px;
  }

  .project-notes {
    grid-template-columns: 1fr;
  }

  .project-media {
    grid-column: auto;
    min-height: 180px;
    aspect-ratio: 16 / 9;
  }

  .process-layout {
    grid-template-columns: 1fr;
    gap: 40px;
  }
  .process-info {
    position: relative;
    top: 0;
  }
  .process-panel {
    gap: 14px;
    padding-left: 24px;
  }

  .process-line {
    top: 0;
    bottom: 0;
    left: 4px;
    width: 1px;
    height: auto;
  }

  .process-fill {
    width: 100%;
    height: 100%;
    transform-origin: top center;
  }

  .process-step {
    padding: 24px 20px;
  }

  .process-step > span {
    left: -26px;
  }

  .contact-grid {
    gap: 16px;
  }
}

@media (max-width: 640px) {
  .section-shell {
    padding: 72px 18px;
  }

  .hero-section {
    padding-top: 64px;
  }

  .nav-shell {
    min-height: 58px;
    padding: 0 18px;
  }

  .announcement-bar {
    padding: 8px 18px;
    font-size: 12px;
  }

  .brand-mark span:last-child {
    display: none;
  }

  .hero-title {
    font-size: 36px;
  }

  .hero-media {
    aspect-ratio: 4 / 3;
  }

  .generated-proof {
    min-height: 180px;
    padding: 24px 16px 18px;
  }

  .generated-proof-label {
    top: 12px;
    left: 16px;
    font-size: 9px;
  }

  .proof-hero-flow {
    grid-template-columns: 78px 24px 82px 24px 78px;
    gap: 4px;
    justify-content: center;
    transform: scale(0.9);
  }

  .proof-pill {
    min-height: 23px;
    padding: 6px 8px;
    font-size: 9px;
  }

  .proof-processor-node {
    min-height: 76px;
  }

  .proof-event-grid {
    grid-template-columns: repeat(2, 1fr);
  }

  .hero-copy,
  .section-header span,
  .service-card p,
  .contact-copy span {
    font-size: 14px;
  }

  .hero-actions,
  .button {
    width: 100%;
  }

  .processor-glow {
    width: 250px;
    height: 250px;
  }

  .hero-facts {
    grid-template-columns: 1fr;
  }

  .hero-facts div,
  .hero-facts div:nth-child(2) {
    border-right: 0;
    border-bottom: 1px solid rgba(0, 0, 0, 0.24);
  }

  .hero-facts div:last-child {
    border-bottom: 0;
  }

  .section-header h2,
  .service-card h2,
  .contact-copy h2 {
    font-size: 32px;
  }

  .feature-card,
  .service-card,
  .contact-copy,
  .contact-panel,
  .project-card {
    padding: 28px;
    border-radius: 30px;
  }

  .project-main h3 {
    font-size: 28px;
  }

  .contact-panel a,
  .contact-panel span {
    align-items: flex-start;
    justify-content: flex-start;
    border-radius: 28px;
    line-height: 1.4;
  }

  .footer-shell {
    flex-direction: column;
    padding: 32px 18px 44px;
  }

  .footer-links {
    justify-content: flex-start;
  }
}

@media (prefers-reduced-motion: reduce) {
  *,
  *::before,
  *::after {
    scroll-behavior: auto !important;
    transition-duration: 0.001ms !important;
    animation-duration: 0.001ms !important;
    animation-iteration-count: 1 !important;
  }
}

