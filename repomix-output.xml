  --sidebar: var(--color-parchment-cream);
  --sidebar-foreground: var(--color-ink-black);
  --sidebar-primary: var(--color-charcoal);
  --sidebar-primary-foreground: var(--color-parchment-cream);
  --sidebar-accent: var(--color-lavender-mist);
  --sidebar-accent-foreground: var(--color-ink-black);
  --sidebar-border: rgba(0, 0, 0, 0.2);
  --sidebar-ring: rgba(0, 0, 0, 0.45);
}

@theme inline {
  --color-background: var(--background);
  --color-foreground: var(--foreground);
  --color-card: var(--card);
  --color-card-foreground: var(--card-foreground);
  --color-popover: var(--popover);
  --color-popover-foreground: var(--popover-foreground);
  --color-primary: var(--primary);
  --color-primary-foreground: var(--primary-foreground);
  --color-secondary: var(--secondary);
  --color-secondary-foreground: var(--secondary-foreground);
  --color-muted: var(--muted);
  --color-muted-foreground: var(--muted-foreground);
  --color-accent: var(--accent);
  --color-accent-foreground: var(--accent-foreground);
  --color-destructive: var(--destructive);
  --color-destructive-foreground: var(--destructive-foreground);
  --color-border: var(--border);
  --color-input: var(--input);
  --color-input-background: var(--input-background);
  --color-switch-background: var(--switch-background);
  --color-ring: var(--ring);
  --radius-sm: 6px;
  --radius-md: 8px;
  --radius-lg: 12px;
  --radius-xl: 40px;
  --color-sidebar: var(--sidebar);
  --color-sidebar-foreground: var(--sidebar-foreground);
  --color-sidebar-primary: var(--sidebar-primary);
  --color-sidebar-primary-foreground: var(--sidebar-primary-foreground);
  --color-sidebar-accent: var(--sidebar-accent);
  --color-sidebar-accent-foreground: var(--sidebar-accent-foreground);
  --color-sidebar-border: var(--sidebar-border);
  --color-sidebar-ring: var(--sidebar-ring);
  --font-serif: var(--font-untitled-serif);
  --font-mono: var(--font-abc-diatype-mono);
  --font-sans: var(--font-untitled-sans);
}

* {
  box-sizing: border-box;
}

html {
  background: var(--color-parchment-cream);
  color: var(--color-ink-black);
  font-size: 16px;
  scroll-behavior: smooth;
}

body {
  min-width: 320px;
  margin: 0;
  background: var(--color-parchment-cream);
  color: var(--color-ink-black);
  font-family: var(--font-abc-diatype-mono);
  line-height: 1.35;
  text-rendering: optimizeLegibility;
  -webkit-font-smoothing: antialiased;
}

button,
input,
textarea,
select {
  font: inherit;
}

button {
  border: 0;
}

a {
  color: inherit;
  text-decoration: none;
}

button:focus-visible,
a:focus-visible {
  outline: 2px solid var(--color-ink-black);
  outline-offset: 4px;
}

::selection {
  background: var(--color-lavender-mist);
  color: var(--color-ink-black);
}

/* App canvas */
.portfolio-root {
  position: relative;
  min-height: 100dvh;
  overflow-x: hidden;
  background:
    linear-gradient(rgba(0, 0, 0, 0.028) 1px, transparent 1px),
    linear-gradient(90deg, rgba(0, 0, 0, 0.024) 1px, transparent 1px),
    var(--color-parchment-cream);
  background-size: 64px 64px;
}

.portfolio-root > main,
.site-header,
.footer-shell {
  position: relative;
  z-index: 2;
}

.ambient-mark {
  position: fixed;
  right: -120px;
  bottom: -140px;
  z-index: 0;
  color: var(--color-ink-black);
  opacity: 0.035;
  pointer-events: none;
}

.site-header {
  position: sticky;
  top: 0;
  background: var(--color-parchment-cream);
}

/* Announcement and navigation */
.announcement-bar {
  display: grid;
  grid-template-columns: 1fr auto auto;
  gap: 12px;
  align-items: center;
  min-height: 48px;
  padding: 8px 24px;
  background: var(--color-ink-black);
  color: var(--color-parchment-cream);
  font-size: 13px;
}

.announcement-bar p {
  margin: 0;
  text-align: center;
}

.announcement-bar button {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  min-height: 32px;
  padding: 6px 14px;
  border: 1px solid var(--color-parchment-cream);
  border-radius: var(--radius-buttons);
  background: var(--color-parchment-cream);
  color: var(--color-ink-black);
  cursor: pointer;
}

.announcement-bar .announcement-close {
  justify-content: center;
  width: 32px;
  padding: 0;
  background: transparent;
  color: var(--color-parchment-cream);
}

.nav-shell {
  display: grid;
  grid-template-columns: 1fr auto 1fr;
  align-items: center;
  gap: 20px;
  max-width: var(--page-max-width);
  min-height: 64px;
  margin: 0 auto;
  padding: 0 24px;
  border-bottom: 1px solid var(--color-ink-black);
  background: var(--color-parchment-cream);
}

.brand-mark,
.nav-links button,
.mobile-menu button,
.footer-links button {
  background: transparent;
  color: var(--color-ink-black);
  cursor: pointer;
}

.brand-mark {
  display: inline-flex;
  align-items: center;
  justify-self: start;
  gap: 10px;
  padding: 0;
  font-size: 14px;
  font-weight: 500;
}

.brand-symbol {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 44px;
  min-height: 28px;
  padding: 0 10px;
  border: 1px solid var(--color-ink-black);
  border-radius: var(--radius-buttons);
  background: var(--color-parchment-cream);
}

.nav-links {
  display: flex;
  align-items: center;
  justify-self: center;
  gap: 22px;
}

.nav-links button {
  padding: 8px 0;
  font-size: 13px;
  color: var(--color-graphite);
  transition: color 180ms ease;
}

.nav-links button:hover {
  color: var(--color-ink-black);
}

.nav-actions {
  display: flex;
  justify-content: flex-end;
  gap: 10px;
}

/* Buttons */
.button {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 9px;
  min-height: 42px;
  padding: 10px 24px;
  border-radius: var(--radius-buttons);
  font-size: 14px;
  font-weight: 500;
  line-height: 1.2;
  cursor: pointer;
  transition:
    transform 180ms ease,
    background 180ms ease,
    color 180ms ease;
}

.button:hover {
  transform: translateY(-1px);
}

.button-filled {
  border: 1px solid var(--color-charcoal);
  background: var(--color-charcoal);
  color: var(--color-parchment-cream);
}

.button-ghost,
.button-link {
  border: 1px solid var(--color-ink-black);
  background: transparent;
  color: var(--color-ink-black);
}

.button-link {
  border-color: rgba(0, 0, 0, 0.28);
}

.mobile-toggle {
  display: none;
  justify-self: end;
  width: 40px;
  height: 40px;
  border: 1px solid var(--color-ink-black);
  border-radius: var(--radius-buttons);
  background: transparent;
  color: var(--color-ink-black);
  cursor: pointer;
}

.mobile-menu {
  display: none;
}

/* Shared section layout */
.section-shell {
  max-width: var(--page-max-width);
  margin: 0 auto;
  padding: 96px 24px;
}

.hero-section {
  padding-top: 104px;
}

/* Hero */
.hero-content {
  width: 100%;
  max-width: 1120px;
  margin: 0 auto;
  text-align: center;
}

.hero-eyebrow,
.section-header p,
.service-kicker,
.contact-copy p {
  margin: 0 0 18px;
  color: var(--color-warm-stone);
  font-size: 13px;
  font-weight: 500;
  text-transform: uppercase;
}

.hero-title {
  max-width: min(1120px, 100%);
  margin: 0 auto 24px;
  color: var(--color-ink-black);
  font-family: var(--font-untitled-serif);
  font-size: 38px;
  font-weight: 400;
  line-height: 1.12;
}

.hero-title .line {
  display: block;
}

.hero-copy {
  max-width: 760px;
  margin: 0 auto;
  color: var(--color-graphite);
  font-size: 16px;
  line-height: 1.65;
}

.hero-actions {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 12px;
  margin-top: 32px;
}

.data-flow {
  position: relative;
  display: grid;
  grid-template-columns: minmax(190px, 1fr) minmax(220px, 350px) minmax(190px, 1fr);
  gap: 28px;
  align-items: center;
  min-height: 430px;
  margin-top: 72px;
  isolation: isolate;
}

.flow-lines {
  position: absolute;
  inset: 48px 10%;
  z-index: 0;
  display: grid;
  grid-template-rows: repeat(4, 1fr);
  pointer-events: none;
}

.flow-lines span {
  align-self: center;
  height: 1px;
  background: linear-gradient(90deg, transparent, rgba(0, 0, 0, 0.26), transparent);
}

.flow-column {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  gap: 14px;
}

.flow-column:first-of-type {
  align-items: flex-start;
}

.flow-column:last-of-type {
  align-items: flex-end;
}

.flow-tag {
  display: inline-flex;
  align-items: center;
  gap: 9px;
  width: fit-content;
  max-width: 100%;
  min-height: 36px;
  padding: 8px 16px;
  border: 1px solid var(--color-ink-black);
  border-radius: var(--radius-buttons);
  background: rgba(246, 243, 241, 0.88);
  color: var(--color-ink-black);
  box-shadow: rgba(0, 0, 0, 0.05) 0 0 10px;
  font-size: 12px;
  white-space: nowrap;
}

.tag-icon {
  width: 8px;
  height: 8px;
  border: 1px solid var(--color-ink-black);
  border-radius: 999px;
  background: var(--color-parchment-cream);
}

.processor {
  position: relative;
  z-index: 2;
  display: grid;
  place-items: center;
  min-height: 310px;
}

.processor-glow {
  position: absolute;
  width: 310px;
  height: 310px;
  border-radius: 50%;
  background:
    radial-gradient(circle, rgba(167, 252, 205, 0.65), rgba(160, 181, 235, 0.34) 42%, transparent 68%),
    radial-gradient(circle at 62% 30%, rgba(255, 148, 115, 0.45), transparent 46%);
  filter: blur(14px);
}

.processor-core {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 10px;
  width: 154px;
  height: 154px;
  border: 1px solid var(--color-ink-black);
  border-radius: 50%;
  background: rgba(246, 243, 241, 0.92);
  color: var(--color-ink-black);
  font-size: 13px;
  font-weight: 500;
  box-shadow: var(--shadow-md);
}

.processor-badges {
  position: absolute;
  right: 0;
  bottom: 26px;
  left: 0;
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 8px;
}

.processor-badges span {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  min-height: 26px;
  padding: 5px 10px;
  border: 1px solid rgba(0, 0, 0, 0.5);
  border-radius: var(--radius-buttons);
  background: rgba(246, 243, 241, 0.8);
  font-size: 11px;
}

.processor-badges i {
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: var(--color-mint-to-periwinkle-wash);
}

.hero-facts {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 0;
  margin-top: 48px;
  border-top: 1px solid var(--color-ink-black);
  border-bottom: 1px solid var(--color-ink-black);
}

.hero-facts div {
  min-height: 96px;
  padding: 20px 22px;
  border-right: 1px solid rgba(0, 0, 0, 0.24);
}

.hero-facts div:last-child {
  border-right: 0;
}

.hero-facts span,
.project-notes span,
.project-index {
  display: block;
  margin-bottom: 8px;
  color: var(--color-warm-stone);
  font-size: 12px;
}

.hero-facts strong {
  display: block;
  color: var(--color-ink-black);
  font-size: 14px;
  font-weight: 500;
  line-height: 1.45;
}

.section-header {
  max-width: 780px;
  margin-bottom: 40px;
}

/* Section headers */
.section-header h2,
.service-card h2,
.contact-copy h2 {
  margin: 0;
  color: var(--color-ink-black);
  font-family: var(--font-untitled-serif);
  font-size: 40px;
  font-weight: 400;
  line-height: 1.2;
}

.section-header span,
.service-card p,
.contact-copy span {
  display: block;
  max-width: 690px;
  margin-top: 18px;
  color: var(--color-graphite);
  font-size: 16px;
  line-height: 1.65;
}

.origin-grid {
  display: grid;
  grid-template-columns: repeat(12, 1fr);
  grid-auto-flow: dense;
  gap: 16px;
}

.feature-card {
  position: relative;
  grid-column: span 4;
  min-height: 410px;
  overflow: hidden;
  padding: 40px;
  border-radius: var(--radius-cards);
  background: var(--color-lavender-mist);
  box-shadow: var(--shadow-md);
}

.origin-grid .feature-card:first-child {
  grid-column: span 5;
}

.origin-grid .feature-card:nth-child(2) {
  grid-column: span 7;
}

.origin-grid .feature-card:nth-child(3) {
  grid-column: span 12;
  min-height: 300px;
}

.feature-icon {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 42px;
  height: 42px;
  margin-bottom: 28px;
  border: 1px solid var(--color-ink-black);
  border-radius: var(--radius-buttons);
  background: rgba(246, 243, 241, 0.45);
}

.feature-card h3,
.process-step h3 {
  margin: 0;
  color: var(--color-ink-black);
  font-family: var(--font-untitled-serif);
  font-size: 24px;
  font-weight: 400;
  line-height: 1.2;
}

.feature-card p,
.process-step p,
.project-notes p {
  margin: 14px 0 0;
  color: var(--color-graphite);
  font-size: 14px;
  line-height: 1.65;
}

/* Media proof frames */
.media-frame {
  position: relative;
  display: grid;
  width: 100%;
  margin: 0;
  overflow: hidden;
  border: 1px solid rgba(0, 0, 0, 0.28);
  border-radius: 32px;
  background:
    linear-gradient(rgba(0, 0, 0, 0.06) 1px, transparent 1px),
    linear-gradient(90deg, rgba(0, 0, 0, 0.05) 1px, transparent 1px),
    rgba(246, 243, 241, 0.78);
  background-size: 22px 22px;
}

.media-frame img,
.media-frame video {
  display: block;
  width: 100%;
  height: 100%;
  min-height: 100%;
  object-fit: cover;
}

.media-frame figcaption {
  position: absolute;
  right: 12px;
  bottom: 12px;
  left: 12px;
  display: flex;
  align-items: center;
  gap: 7px;
  min-height: 30px;
  width: fit-content;
  max-width: calc(100% - 24px);
  padding: 7px 11px;
  border: 1px solid rgba(0, 0, 0, 0.32);
  border-radius: var(--radius-buttons);
  background: rgba(246, 243, 241, 0.88);
  color: var(--color-ink-black);
  font-size: 11px;
}

.media-frame-fallback {
  display: grid;
  place-items: center;
  align-content: center;
  gap: 10px;
  min-height: 100%;
  padding: 28px;
  color: var(--color-graphite);
  font-size: 12px;
  text-align: center;
}

.media-frame-overlay {
  position: absolute;
  inset: 0;
  background:
    linear-gradient(rgba(0, 0, 0, 0.06) 1px, transparent 1px),
    linear-gradient(90deg, rgba(0, 0, 0, 0.05) 1px, transparent 1px),
    rgba(246, 243, 241, 0.9);
  background-size: 22px 22px;
}

.generated-proof {
  position: relative;
  display: grid;
  align-content: center;
  width: 100%;
  height: 100%;
  min-height: 140px;
  padding: 28px;
  overflow: hidden;
  color: var(--color-ink-black);
}

.portfolio-root {
  min-height: 100vh;
  position: relative;
  overflow: hidden;
}

.theme-tint-overlay {
  position: fixed;
  inset: 0;
  pointer-events: none;
  z-index: 0;
  background-color: var(--color-lavender-mist);
  opacity: 0;
  transition: opacity 0.8s ease;
  mix-blend-mode: multiply;
}

.has-dynamic-theme .theme-tint-overlay {
  opacity: 0.08;
}

.generated-proof::before {
  content: "";
  position: absolute;
  inset: 18px;
  border: 1px solid rgba(0, 0, 0, 0.12);
  border-radius: 24px;
  pointer-events: none;
}

.generated-proof-label {
  position: absolute;
  top: 16px;
  left: 18px;
  z-index: 3;
  display: inline-flex;
  align-items: center;
  gap: 8px;
  max-width: calc(100% - 36px);
  color: var(--color-graphite);
  font-size: 10px;
  line-height: 1.1;
  text-transform: uppercase;
}

.generated-proof-label i {
  width: 7px;
  height: 7px;
  border: 1px solid var(--color-ink-black);
  border-radius: 999px;
  background: rgba(167, 252, 205, 0.62);
  animation: proof-pulse 2.4s ease-in-out infinite;
}

.proof-pill {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 24px;
  padding: 6px 10px;
  border: 1px solid rgba(0, 0, 0, 0.34);
  border-radius: var(--radius-buttons);
  background: rgba(246, 243, 241, 0.78);
  color: var(--color-ink-black);
  font-size: 10px;
  line-height: 1;
  white-space: nowrap;
}

.proof-pill.is-active {
  background: rgba(207, 218, 245, 0.74);
}

.proof-hero-flow,
.proof-story-structure,
.proof-service {
  display: grid;
  grid-template-columns: minmax(72px, 1fr) 44px minmax(82px, 0.8fr) 44px minmax(72px, 1fr);
  gap: 10px;
  align-items: center;
  padding-top: 14px;
}

.proof-flow-column {
  display: grid;
  gap: 8px;
}

.proof-flow-rail {
  position: relative;
  height: 1px;
  background: rgba(0, 0, 0, 0.34);
}

.proof-flow-rail::before,
.proof-flow-rail::after {
  content: "";
  position: absolute;
  top: -3px;
  width: 7px;
  height: 7px;
  border: 1px solid rgba(0, 0, 0, 0.5);
  border-radius: 999px;
  background: var(--color-parchment-cream);
}

.proof-flow-rail::before {
  left: -2px;
}

.proof-flow-rail::after {
  right: -2px;
}

.proof-moving-dot {
  position: absolute;
  top: -4px;
  left: 0;
  width: 9px;
  height: 9px;
  border-radius: 999px;
  background: var(--color-ink-black);
  animation: proof-flow 2.8s linear infinite;
}

.proof-processor-node {
  display: grid;
  place-items: center;
  gap: 4px;
  min-height: 82px;
  border: 1px solid var(--color-ink-black);
  border-radius: 28px;
  background:
    radial-gradient(circle at 50% 45%, rgba(167, 252, 205, 0.55), transparent 54%),
    rgba(246, 243, 241, 0.86);
  box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.24);
  animation: proof-node 3.8s ease-in-out infinite;
}

.proof-processor-node span {
  font-size: 12px;
}

.proof-processor-node small {
  color: var(--color-graphite);
  font-size: 9px;
}

.proof-system-map {
  position: relative;
  min-height: 168px;
}

.proof-map-node {
  position: absolute;
  z-index: 2;
  display: grid;
  gap: 8px;
  width: 34%;
  min-width: 92px;
  padding: 10px;
  border: 1px solid rgba(0, 0, 0, 0.35);
  border-radius: 20px;
  background: rgba(246, 243, 241, 0.86);
  font-size: 10px;
}

.proof-map-node i {
  display: block;
  height: 4px;
  border-radius: 999px;
  background: rgba(0, 0, 0, 0.18);
}

.proof-map-node-1 { top: 20px; left: 4%; }
.proof-map-node-2 { top: 20px; left: 34%; }
.proof-map-node-3 { top: 20px; right: 4%; }
.proof-map-node-4 { bottom: 16px; left: 12%; }
.proof-map-node-5 { bottom: 16px; left: 42%; }
.proof-map-node-6 { bottom: 16px; right: 8%; }

.proof-map-line {
  position: absolute;
  left: 11%;
  right: 11%;
  height: 1px;
  background: rgba(0, 0, 0, 0.24);
}

.proof-map-line-a { top: 58px; }
.proof-map-line-b { bottom: 54px; }
.proof-map-line-c {
  top: 58px;
  bottom: 54px;
  left: 50%;
  width: 1px;
  height: auto;
}

.proof-story-structure {
  grid-template-columns: 1fr 42px 1fr;
}

.proof-wireframe {
  display: grid;
  gap: 8px;
  min-height: 126px;
  padding: 14px;
  border: 1px solid rgba(0, 0, 0, 0.34);
  border-radius: 22px;
  background: rgba(246, 243, 241, 0.82);
}

.proof-wireframe span {
  color: var(--color-warm-stone);
  font-size: 10px;
}

.proof-wireframe i {
  display: block;
  height: 9px;
  border-radius: 999px;
  background: rgba(0, 0, 0, 0.16);
}

.proof-wireframe-after i {
  background: rgba(0, 0, 0, 0.24);
}

.proof-wireframe .wide {
  width: 78%;
}

.proof-structure-arrow {
  position: relative;
  height: 1px;
  background: rgba(0, 0, 0, 0.32);
}

.proof-structure-arrow::after {
  content: "";
  position: absolute;
  top: -4px;
  right: -1px;
  width: 8px;
  height: 8px;
  border-top: 1px solid rgba(0, 0, 0, 0.5);
  border-right: 1px solid rgba(0, 0, 0, 0.5);
  transform: rotate(45deg);
}

.proof-finance-dashboard,
.proof-support-wall,
.proof-event-landing,
.proof-game-interface {
  display: grid;
  gap: 12px;
  padding-top: 18px;
}

.proof-finance-header {
  display: flex;
  justify-content: space-between;
  gap: 14px;
  padding: 13px 14px;
  border: 1px solid rgba(0, 0, 0, 0.34);
  border-radius: 22px;
  background: rgba(246, 243, 241, 0.8);
}

.proof-finance-header span,
.proof-budget-bars span {
  color: var(--color-warm-stone);
  font-size: 10px;
}

.proof-finance-header strong {
  font-family: var(--font-untitled-serif);
  font-size: 26px;
  font-weight: 400;
}

.proof-budget-bars {
  display: grid;
  gap: 8px;
}

.proof-budget-bars div {
  display: grid;
  grid-template-columns: 58px 1fr;
  gap: 10px;
  align-items: center;
}

.proof-budget-bars i {
  display: block;
  height: 8px;
  border-radius: 999px;
  background:
    linear-gradient(90deg, rgba(0, 0, 0, 0.72) var(--proof-fill), rgba(0, 0, 0, 0.12) var(--proof-fill));
  animation: proof-bar 4s ease-in-out infinite;
}

.proof-finance-chip,
.proof-game-dialog {
  width: fit-content;
  max-width: 100%;
  padding: 8px 12px;
  border: 1px solid rgba(0, 0, 0, 0.34);
  border-radius: var(--radius-buttons);
  background: rgba(207, 218, 245, 0.72);
  font-size: 10px;
}

.proof-support-wall {
  grid-template-columns: 1.05fr 0.95fr;
}

.proof-note-card,
.proof-moderation-queue {
  min-height: 78px;
  padding: 13px;
  border: 1px solid rgba(0, 0, 0, 0.32);
  border-radius: 22px;
  background: rgba(246, 243, 241, 0.84);
  color: var(--color-graphite);
  font-size: 11px;
  line-height: 1.45;
}

.proof-note-card.is-muted {
  transform: translateY(18px);
  background: rgba(207, 218, 245, 0.62);
}

.proof-moderation-queue {
  grid-column: 1 / -1;
  display: grid;
  grid-template-columns: 90px repeat(3, 1fr);
  gap: 8px;
  min-height: auto;
}

.proof-moderation-queue i {
  border-radius: 999px;
  background: rgba(0, 0, 0, 0.16);
}

.proof-event-hero {
  display: grid;
  grid-template-columns: 1fr auto;
  gap: 16px;
  align-items: center;
  min-height: 72px;
  padding: 14px;
  border: 1px solid rgba(0, 0, 0, 0.34);
  border-radius: 24px;
  background: rgba(246, 243, 241, 0.82);
}

.proof-event-hero span {
  font-family: var(--font-untitled-serif);
  font-size: 26px;
}

.proof-event-hero button {
  min-height: 30px;
  padding: 7px 12px;
  border: 1px solid var(--color-ink-black);
  border-radius: var(--radius-buttons);
  background: var(--color-charcoal);
  color: var(--color-parchment-cream);
  font: inherit;
  font-size: 10px;
}

.proof-event-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 8px;
}

.proof-event-grid i {
  display: grid;
  place-items: center;
  min-height: 42px;
  border: 1px solid rgba(0, 0, 0, 0.24);
  border-radius: 18px;
  background: rgba(246, 243, 241, 0.7);
  font-style: normal;
  font-size: 10px;
}

.proof-game-interface {
  min-height: 152px;
}

.proof-game-hud {
  display: flex;
  justify-content: space-between;
  gap: 10px;
  font-size: 10px;
}

.proof-game-hud span {
  padding: 7px 10px;
  border: 1px solid rgba(0, 0, 0, 0.34);
  border-radius: var(--radius-buttons);
  background: rgba(246, 243, 241, 0.82);
}

.proof-game-stage {
  position: relative;
  min-height: 74px;
  border: 1px solid rgba(0, 0, 0, 0.28);
  border-radius: 22px;
  background:
    linear-gradient(rgba(0, 0, 0, 0.08) 1px, transparent 1px),
    linear-gradient(90deg, rgba(0, 0, 0, 0.07) 1px, transparent 1px),
    rgba(246, 243, 241, 0.78);
  background-size: 18px 18px;
}

.proof-game-player,
.proof-game-target {
  position: absolute;
  bottom: 18px;
  display: block;
  width: 20px;
  height: 20px;
  border: 1px solid var(--color-ink-black);
  border-radius: 50%;
}

.proof-game-player {
  left: 22%;
  background: rgba(167, 252, 205, 0.7);
  animation: proof-drift 3.2s ease-in-out infinite;
}

.proof-game-target {
  right: 22%;
  background: rgba(207, 218, 245, 0.78);
}

.proof-service {
  grid-template-columns: 1fr 1fr minmax(120px, 0.9fr);
}

.proof-service-column {
  display: grid;
  gap: 8px;
  padding: 12px;
  border: 1px solid rgba(0, 0, 0, 0.3);
  border-radius: 22px;
  background: rgba(246, 243, 241, 0.78);
}

.proof-service-column span,
.proof-service-checklist b {
  font-size: 10px;
  font-weight: 400;
}

.proof-service-column i {
  display: block;
  height: 9px;
  border-radius: 999px;
  background: rgba(0, 0, 0, 0.16);
}

.proof-service-column.is-after i {
  background: rgba(0, 0, 0, 0.28);
}

.proof-service-checklist {
  display: grid;
  gap: 8px;
}

.proof-service-checklist b {
  display: flex;
  align-items: center;
  min-height: 28px;
  padding: 8px 10px;
  border: 1px solid rgba(0, 0, 0, 0.3);
  border-radius: var(--radius-buttons);
  background: rgba(207, 218, 245, 0.62);
}

@keyframes proof-flow {
  0% { transform: translateX(0); opacity: 0; }
  12% { opacity: 1; }
  85% { opacity: 1; }
  100% { transform: translateX(44px); opacity: 0; }
}

@keyframes proof-node {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.035); }
}

@keyframes proof-pulse {
  0%, 100% { transform: scale(1); opacity: 0.6; }
  50% { transform: scale(1.35); opacity: 1; }
}

@keyframes proof-bar {
  0%, 100% { opacity: 0.76; }
  50% { opacity: 1; }
}

@keyframes proof-drift {
  0%, 100% { transform: translateX(0); }
  50% { transform: translateX(18px); }
}

.hero-media {
  max-width: 600px;
  aspect-ratio: 16 / 6;
  margin: 30px auto 0;
}

.feature-media {
  aspect-ratio: 16 / 8;
  margin-top: 28px;
}

.capability-strip {
  position: relative;
  display: block;
  max-width: 100%;
  margin-top: 16px;
  overflow: hidden;
  mask-image: linear-gradient(90deg, transparent, #000 7%, #000 93%, transparent);
}

.capability-track {
  display: flex;
  width: max-content;
  animation: capability-marquee 24s linear infinite;
  will-change: transform;
}

.capability-group {
  display: flex;
  flex: 0 0 auto;
  gap: 10px;
  padding-right: 10px;
}

.capability-strip:hover .capability-track {
  animation-play-state: paused;
}

@keyframes capability-marquee {
  from {
    transform: translate3d(0, 0, 0);
  }

  to {
    transform: translate3d(-50%, 0, 0);
  }
}

.capability-strip span {
  display: inline-flex;
  align-items: center;
  min-height: 38px;
  padding: 8px 16px;
  border: 1px solid var(--color-ink-black);
  border-radius: var(--radius-buttons);
  background: var(--color-parchment-cream);
  color: var(--color-ink-black);
  font-size: 12px;
}

.project-stack {
  display: grid;
  gap: 18px;
}

/* Projects */
.project-card {
  position: relative;
  display: grid;
  grid-template-columns: 64px minmax(240px, 0.58fr) minmax(420px, 1.42fr);
  gap: 28px;
  overflow: visible;
  padding: 32px;
  border: 1px solid var(--color-ink-black);
  border-radius: var(--radius-cards);
  background: rgba(246, 243, 241, 0.72);
  transition:
    border-color 260ms ease,
    background-color 260ms ease,
    transform 260ms ease;
}

.project-card:hover,
.project-card.is-active {
  border-color: rgba(0, 0, 0, 0.72);
  background: rgba(246, 243, 241, 0.88);
}

.project-card:hover .project-media,
.project-card.is-active .project-media {
  transform: translateY(-4px) scale(1.02);
}

.project-main p {
  margin: 0 0 12px;
  color: var(--color-warm-stone);
  font-size: 12px;
}

.project-main h3 {
  max-width: 360px;
  margin: 0;
  color: var(--color-ink-black);
  font-family: var(--font-untitled-serif);
  font-size: 32px;
  font-weight: 400;
  line-height: 1.15;
}

.project-notes {
  position: relative;
  z-index: 2;
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 24px;
}

.project-media {
  grid-column: 2 / -1;
  align-self: stretch;
  min-height: clamp(320px, 44vw, 560px);
  aspect-ratio: 16 / 9;
  background: rgba(246, 243, 241, 0.92);
  transition: transform 420ms ease;
}

.project-media img,
.project-media video {
  object-fit: contain;
  object-position: center top;
}

.media-fontOfIntent {
  aspect-ratio: 16 / 8.5;
}

.media-financeTracker,
.media-pingball {
  aspect-ratio: 16 / 9;
}

.media-unsaidWords {
  aspect-ratio: 16 / 10;
}

.media-gamePrototype {
  min-height: clamp(220px, 28vw, 360px);
  aspect-ratio: 16 / 5.8;
}

.process-layout {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 60px;
  align-items: start;
}

.process-info {
  position: sticky;
  top: 100px;
}

.process-extra {
  margin-top: 24px;
  font-family: var(--font-ui);
  font-size: 15px;
  color: var(--color-iron);
  line-height: 1.6;
}

.process-extra p {
  margin-bottom: 12px;
}

.process-panel {
  position: relative;
  display: grid;
  grid-template-columns: 1fr;
  gap: 20px;
  padding: 0 0 0 34px;
}

.process-line {
  position: absolute;
  top: 24px;
  bottom: 24px;
  left: 10px;
  width: 1px;
  height: auto;
  overflow: hidden;
  background: rgba(0, 0, 0, 0.2);
}

.process-fill {
  display: block;
  width: 100%;
  height: 100%;
  transform: scaleY(0);
  transform-origin: top center;
  background: var(--color-ink-black);
}

.process-step {
  position: relative;
  padding: 32px 28px;
  border: 1px solid rgba(0, 0, 0, 0.28);
  border-radius: 24px;
  background: rgba(246, 243, 241, 0.76);
  transition:
    border-color 240ms ease,
    background-color 240ms ease,
    transform 240ms ease;
}

.process-step.is-active {
  border-color: rgba(0, 0, 0, 0.72);
  background: rgba(207, 218, 245, 0.42);
}

.process-step > span {
  position: absolute;
  top: 50%;
  left: -30px;
  transform: translateY(-50%);
  width: 13px;
  height: 13px;
  border: 1px solid var(--color-ink-black);
  border-radius: 50%;
  background: var(--color-parchment-cream);
  transition: background-color 240ms ease, transform 240ms ease;
}

.process-step.is-active > span {
  background: var(--color-ink-black);
  transform: translateY(-50%) scale(1.18);
}

.service-card {
  display: grid;
  grid-template-columns: minmax(0, 1.1fr) minmax(280px, 0.9fr);
  gap: 40px;
  align-items: center;
  overflow: hidden;
  padding: 48px;
  border-radius: var(--radius-cards);
  background: var(--color-lavender-mist);
  box-shadow: var(--shadow-md);
}

.service-card .button {
  margin-top: 28px;
}

.service-detail-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 10px;
  margin-top: 28px;
}

.service-detail-grid article {
  min-height: 136px;
  padding: 18px;
  border: 1px solid rgba(0, 0, 0, 0.32);
  border-radius: 26px;
  background: rgba(246, 243, 241, 0.58);
}

.service-detail-grid h3 {
  margin: 0;
  color: var(--color-ink-black);
  font-size: 12px;
  font-weight: 500;
}

.service-detail-grid p {
  margin: 10px 0 0;
  font-size: 12px;
  line-height: 1.55;
}

.service-proof {
  display: grid;
  gap: 12px;
}

.service-proof-wrap {
  display: grid;
  gap: 14px;
}

.service-media {
  aspect-ratio: 16 / 9;
}

/* Service and contact */
.service-proof div,
.contact-panel a,
.contact-panel span {
  display: flex;
  align-items: center;
  gap: 12px;
  min-height: 54px;
  padding: 14px 16px;
  border: 1px solid var(--color-ink-black);
  border-radius: var(--radius-buttons);
  background: rgba(246, 243, 241, 0.72);
  color: var(--color-ink-black);
  font-size: 13px;
}

.contact-grid {
  display: grid;
  grid-template-columns: minmax(0, 5fr) minmax(320px, 7fr);
  gap: 24px;
  align-items: stretch;
}

.contact-copy,
.contact-panel {
  padding: 40px;
  border: 1px solid var(--color-ink-black);
  border-radius: var(--radius-cards);
  background: rgba(246, 243, 241, 0.68);
}

.contact-panel {
  display: grid;
  align-content: center;
  gap: 12px;
}

.contact-panel a,
.contact-panel span {
  justify-content: space-between;
  border-color: rgba(0, 0, 0, 0.32);
}

.contact-panel a svg:first-child,
.contact-panel span svg:first-child {
  flex: 0 0 auto;
}

.footer-shell {
  display: flex;
  justify-content: space-between;
  gap: 32px;
  max-width: var(--page-max-width);
  margin: 0 auto;
  padding: 40px 24px 56px;
  border-top: 1px solid var(--color-ink-black);
}

.footer-shell strong {
  display: block;
  margin-bottom: 8px;
  color: var(--color-ink-black);
  font-size: 14px;
  font-weight: 500;
}

.footer-shell p {
  max-width: 430px;
  margin: 0;
  color: var(--color-graphite);
  font-size: 13px;
  line-height: 1.55;
}

.footer-links {
  display: flex;
  flex-wrap: wrap;
  justify-content: flex-end;
  gap: 12px;
}

.footer-links button {
  color: var(--color-graphite);
  font-size: 13px;
}

/* ─── Three.js background canvas ─── */
.three-bg-canvas {
  position: fixed;
  inset: 0;
  z-index: 0;
  pointer-events: none;
  opacity: 0.12;
}

/* ─── Parallax depth layer ─── */
.parallax-layer {
  will-change: transform;
}

/* ─── Section divider ─── */
.section-divider {
  max-width: var(--page-max-width);
  height: 1px;
  margin: 0 auto;
  padding: 0 24px;
  background: linear-gradient(90deg, transparent, rgba(0,0,0,0.22), transparent);
}

/* ─── Capability marquee accessibility fallback ─── */
.capability-strip::-webkit-scrollbar {
  display: none;
}

@media (prefers-reduced-motion: reduce) {
  .capability-strip {
    overflow-x: auto;
    scrollbar-width: none;
    -webkit-overflow-scrolling: touch;
    mask-image: none;
  }

  .capability-track {
    animation: none;
  }
}

/* ─── Hero gradient wash ─── */
.hero-content::before {
  content: '';
  position: absolute;
  top: -60px;
  left: 50%;
  transform: translateX(-50%);
  width: 680px;
  height: 420px;
  background: radial-gradient(ellipse at 50% 40%, rgba(207,218,245,0.28), rgba(167,252,205,0.12) 48%, transparent 72%);
  pointer-events: none;
  z-index: -1;
}

.hero-content {
  position: relative;
}

/* ─── Section entrance transitions (no-JS fallback) ─── */
.origin-section,
.projects-section,
.process-section,
.service-section,
.contact-section {
  position: relative;
}

.service-section {
  padding-bottom: 56px;
}

.contact-section {
  padding-top: 56px;
}

/* ─── Project card parallax indicator ─── */
.project-card::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 3px;
  background: linear-gradient(90deg, transparent, var(--color-lavender-mist), transparent);
  opacity: 0;
  transition: opacity 320ms ease;
}

.project-card:hover::after,
.project-card.is-active::after {
  opacity: 1;
}

/* ─── Nav scroll shadow ─── */
.site-header {
  transition: box-shadow 280ms ease;
}

.site-header.has-scrolled {
  box-shadow: 0 1px 12px rgba(0,0,0,0.06);
}

/* ─── Boot Screen ─── */
.boot-screen {
  position: fixed;
  inset: 0;
  z-index: 9999;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--color-parchment-cream);
  color: var(--color-graphite);
}

.boot-grid {
  position: absolute;
  inset: 0;
  background:
    linear-gradient(rgba(0, 0, 0, 0.028) 1px, transparent 1px),
    linear-gradient(90deg, rgba(0, 0, 0, 0.024) 1px, transparent 1px);
  background-size: 64px 64px;
  pointer-events: none;
}

.boot-content {
  position: relative;
  z-index: 1;
  width: calc(100% - 64px);
  max-width: 840px;
  padding: 64px;
  border: 1px solid rgba(0,0,0,0.15);
  background: var(--color-parchment-cream);
  box-shadow: 0 4px 24px rgba(0,0,0,0.04);
}

.boot-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 60px;
}

.boot-badge {
  font-family: var(--font-mono);
  font-size: 11px;
  padding: 4px 10px;
  border: 1px solid var(--color-ink-black);
  border-radius: 999px;
  text-transform: uppercase;
  letter-spacing: 0.05em;
}

.boot-skip {
  font-family: var(--font-mono);
  font-size: 11px;
  color: var(--color-iron);
  background: none;
  border: none;
  cursor: pointer;
  text-transform: uppercase;
  transition: color 0.2s;
}

.boot-skip:hover {
  color: var(--color-ink-black);
}

.boot-main h1 {
  font-size: 42px;
  font-weight: 300;
  margin-bottom: 12px;
  letter-spacing: -0.5px;
}

.boot-subtitle {
  font-size: 14px;
  color: var(--color-steel);
  margin-bottom: 48px;
}

.boot-flow {
  display: flex;
  align-items: center;
  gap: 12px;
  font-family: var(--font-mono);
  font-size: 12px;
  color: var(--color-graphite);
  margin-bottom: 64px;
}

.boot-flow-arrow {
  color: var(--color-iron);
}

.boot-modules {
  margin-bottom: 60px;
}

.boot-modules-title {
  font-size: 11px;
  color: var(--color-iron);
  margin-bottom: 16px;
  text-transform: uppercase;
  letter-spacing: 0.05em;
}

.boot-modules ul {
  list-style: none;
  padding: 0;
  margin: 0;
  display: flex;
  flex-direction: column;
  gap: 16px;
}

.boot-modules li {
  display: flex;
  align-items: center;
  font-family: var(--font-mono);
  font-size: 14px;
  color: var(--color-graphite);
}

.boot-module-status {
  width: 6px;
  height: 6px;
  border-radius: 50%;
  margin-right: 12px;
  background: var(--color-iron);
  transition: background-color 0.3s;
}

.boot-modules li.is-ready .boot-module-status {
  background: var(--color-mint-chill);
  box-shadow: 0 0 8px var(--color-mint-chill);
}

.boot-module-name {
  width: 120px;
}

.boot-module-state {
  color: var(--color-steel);
  font-size: 12px;
}

.boot-modules li.is-ready .boot-module-state {
  color: var(--color-graphite);
}

.boot-modules li.is-clickable {
  cursor: pointer;
  transition: transform 0.2s cubic-bezier(0.4, 0, 0.2, 1);
  padding: 8px 0;
}

.boot-modules li.is-clickable:hover {
  transform: translateX(6px);
}

.boot-modules li.is-clickable:hover .boot-module-status {
  background: var(--color-ink-black);
  box-shadow: none;
}

.boot-modules li.is-clickable:hover .boot-module-state {
  color: var(--color-ink-black);
  font-weight: 600;
}

.boot-progress-container {
  display: flex;
  align-items: center;
  gap: 16px;
}

.boot-progress-bar {
  flex: 1;
  height: 2px;
  background: rgba(0,0,0,0.1);
  position: relative;
}

.boot-progress-fill {
  position: absolute;
  top: 0;
  left: 0;
  height: 100%;
  background: var(--color-ink-black);
  transition: width 0.1s linear;
}

.boot-progress-text {
  font-size: 12px;
  color: var(--color-graphite);
  width: 40px;
  text-align: right;
}

.boot-ready-prompt {
  margin-top: 40px;
  font-family: var(--font-mono);
  font-size: 12px;
  text-align: center;
  color: var(--color-ink-black);
  text-transform: uppercase;
  letter-spacing: 0.1em;
  cursor: pointer;
  animation: prompt-blink 1.5s infinite;
}

@keyframes prompt-blink {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.3; }
}

/* ─── Cursor trail dot (desktop only) ─── */
.cursor-dot {
  position: fixed;
  width: 8px;
  height: 8px;
  border-radius: 50%;
  background: var(--color-ink-black);
  pointer-events: none;
  z-index: 9999;
  opacity: 0.35;
  mix-blend-mode: difference;
  transition: transform 80ms ease, opacity 200ms ease;
}

@media (hover: none), (pointer: coarse), (prefers-reduced-motion: reduce), (max-width: 1023px) {
  .cursor-dot {
    display: none !important;
  }
